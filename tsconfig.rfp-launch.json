{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "proxy.ts",
    "app/robots.ts",
    "app/sitemap.ts",
    "app/(rfp-marketing)/**/*.ts",
    "app/(rfp-marketing)/**/*.tsx",
    "app/api/cron/rfp-*/**/*.ts",
    "app/api/health/rfp/**/*.ts",
    "app/api/rfp/**/*.ts",
    "app/api/webhooks/rfp-stripe/**/*.ts",
    "app/contact-sales/rfp-engine/**/*.ts",
    "app/contact-sales/rfp-engine/**/*.tsx",
    "components/rfp/**/*.ts",
    "components/rfp/**/*.tsx",
    "components/ui/**/*.ts",
    "components/ui/**/*.tsx",
    "lib/rfp/**/*.ts",
    "lib/supabase/**/*.ts",
    "lib/env.ts",
    "lib/utils.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
