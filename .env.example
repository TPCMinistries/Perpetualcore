# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to skip environment validation (not recommended for production)
# SKIP_ENV_VALIDATION=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
# Default From: address for transactional emails. Domain must be verified in Resend.
# RESEND_FROM_EMAIL=noreply@perpetualcore.com
# Plan 05-07 — override sender for high-fit RFP alerts only.
# Runtime fallback: RFP_ALERT_FROM_EMAIL ?? RESEND_FROM_EMAIL ?? 'noreply@perpetualcore.com'
# RFP_ALERT_FROM_EMAIL=alerts@perpetualcore.com

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Integrations - Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Integrations - Zoom
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Integrations - Google Drive
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Price IDs (server-side only — create these in Stripe Dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxx
STRIPE_STARTER_ANNUAL_PRICE_ID=price_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
STRIPE_TEAM_MONTHLY_PRICE_ID=price_xxx
STRIPE_TEAM_ANNUAL_PRICE_ID=price_xxx
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_xxx
STRIPE_BUSINESS_ANNUAL_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_xxx

# Security - Encryption (REQUIRED for 2FA)
ENCRYPTION_KEY=your-secure-encryption-key-min-32-characters

# Agent Runtime (Phase 1-3)
E2B_API_KEY=your-e2b-api-key
BROWSERLESS_API_KEY=your-browserless-api-key
CRON_SECRET=your-cron-secret-for-plan-self-chaining
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Redis (Upstash) - Rate Limiting & Caching
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Meeting Intelligence Webhooks
FATHOM_WEBHOOK_SECRET=your-fathom-webhook-secret
DEFAULT_WEBHOOK_USER_ID=your-default-user-uuid

# RFP & Proposal Engine — Discovery sources (Phase 5)
# SAM.gov — Federal contract opportunities.
# Key: https://sam.gov → Account → API Keys (free tier: 1,000 req/day).
# For production: register a SYSTEM account at https://fsd.gov → System Account (non-expiring).
# Individual keys expire every 90 days; system accounts avoid that churn.
# After fsd.gov approval: set this value AND run:
#   UPDATE rfp_api_key_health SET expires_at = '<issued_date + 90 days>', updated_at = now() WHERE key_name = 'sam_gov';
# (If system-account keys truly don't expire, leave expires_at NULL — alerting won't fire.)
# Key is OPTIONAL at boot — Phase 5 skips SAM source when key is absent.
SAM_GOV_API_KEY=your-sam-gov-api-key
# Override default if the SAM.gov API base URL ever changes.
# SAM_GOV_BASE_URL=https://api.sam.gov/prod/opportunities/v2

# Grants.gov — Federal grant opportunities.
# No auth required for the search2 endpoint. Base URL is stable; override if needed.
# GRANTS_GOV_BASE_URL=https://api.grants.gov/v1/api

# Simpler.Grants.gov — Modern federal grants portal.
# Key: https://api.simpler.grants.gov → Generate Key (~5 minutes).
# Key is OPTIONAL at boot — Phase 5 skips Simpler Grants source when key is absent.
SIMPLER_GRANTS_API_KEY=your-simpler-grants-api-key
# Override default if the Simpler Grants base URL ever changes.
# SIMPLER_GRANTS_BASE_URL=https://api.simpler.grants.gov/v1

# SBIR.gov — SBIR/STTR solicitations.
# No auth required. Base URL is stable; override if needed.
# SBIR_GOV_BASE_URL=https://www.sbir.gov/api
